---
// BlogPostingSchema.astro
// Renders BlogPosting JSON-LD for individual blog posts
import { Schema } from 'astro-seo-schema';

interface Props {
	title: string;
	description?: string;
	pubDate: Date | string;
	author: string;
	image?: string;
}

const { title, description, pubDate, author, image } = Astro.props;
const siteUrl = 'https://promptmarketing.com';
const pageUrl = Astro.url.href;

// Handle pubDate as either Date object or ISO string (Sanity returns strings)
const dateObj = pubDate instanceof Date ? pubDate : new Date(pubDate);

// Use seoDescription if provided, otherwise fall back to title-based description
const desc = description || `${title} - PromptMarketing Blog`;
---

<Schema
	item={{
		'@context': 'https://schema.org',
		'@type': 'BlogPosting',
		headline: title,
		description: desc,
		image: image ? [image.startsWith('http') ? image : `${siteUrl}${image}`] : undefined,
		datePublished: dateObj.toISOString(),
		author: {
			'@type': 'Person',
			name: author
		},
		publisher: {
			'@type': 'Organization',
			'@id': `${siteUrl}/#organization`,
			name: 'PromptMarketing',
			logo: {
				'@type': 'ImageObject',
				url: `${siteUrl}/pm-logo-dark.png`
			}
		},
		mainEntityOfPage: {
			'@type': 'WebPage',
			'@id': pageUrl
		}
	}}
/>
