---
// Home Page
// ------------
// Description: The home page is a page that displays the most important information.

// Components
// - Layout
import Layout from '../layouts/Layout.astro'

// - SEO Schemas
import OrganizationSchema from '../components/seo/OrganizationSchema.astro'
import WebSiteSchema from '../components/seo/WebSiteSchema.astro'
import FAQPageSchema from '../components/seo/FAQPageSchema.astro'
import ServiceSchema from '../components/seo/ServiceSchema.astro'

// - Blocks
import Hero from '../components/blocks/hero/CenteredHeroCTA.astro'
import Brand from '../components/blocks/brand/Marquee.astro'
import Features from '../components/blocks/features/FourPillarsGrid.astro'
import ScrollSpySteps from '../components/blocks/onboarding/Steps.astro'
import TestimonialMasonry from '../components/blocks/testimonials/TestimonialMasonry.astro'
import Faq from '../components/blocks/faq/StickyFaq.astro'
import CTA from '../components/blocks/cta/CTAPrimary.astro'

// Content
// - SEO
const SEO = {
	title: 'PromptMarketing | Search Marketing for Generative AI',
	description:
		'We ensure your brand is not just indexed, but understood, preferred, and selected by the Generative AI ecosystem. Relevance Engineering for the AI-first economy'
}
// - Hero data
const heroData = {
	title: 'Search Marketing for Generative AI',
	subtitle: 'We ensure your brand is not just indexed, but understood, preferred, and selected by the Generative AI ecosystem.',
	buttonLink: '/contact',
	buttonText: 'Get a GEO Readiness Audit',
	buttonClasses:
		'w-full lg:w-auto rounded-full border-2 border-primary-500 bg-white! text-primary-500! font-bold hover:bg-primary-500! hover:text-white! hover:border-primary-500!'
}
// - Brand data
const brandData = {
	title: 'Trusted by Innovative Brands'
}
// - Testimonial data
const testimonialData = {
	title: 'What Experts Say About AI Search',
	subtitle: 'The Importance of GEO'
}
// - FAQ data
const faqData = {
	title: 'Common Questions',
	subtitle: 'About Relevance Engineering'
}
// - FAQ schema data
const faqSchemaItems = [
	{ question: 'How is this different from traditional SEO?', answer: 'Traditional SEO ranks pages for human clicks. PromptMarketing optimises for LLM synthesis, ensuring AI models recommend your brand as the "chosen" entity in conversational answers.' },
	{ question: 'What is a "Selection Rate"?', answer: 'This is our primary KPI. It quantifies how often AI systems choose your brand as the recommended solution when answering category-specific queries.' },
	{ question: 'Can you help with the "Zero-Click" problem?', answer: "Yes. We target AEO (Answer Engine Optimisation) to ensure that even when a user doesn't click, your brand is the cited authority providing the answer." },
	{ question: 'What is an LLM?', answer: 'Large Language Model, aka AI Chatbot (ChatGPT, Gemini, Google AI Mode, Perplexity, Claude et al.)' },
	{ question: 'What is Prompt Tracking?', answer: 'Visibility sampling in LLMs.' },
	{ question: 'What is AEO?', answer: 'Answer Engine Optimisation; target zero-click answer boxes, citations & AI Overviews.' },
	{ question: 'What is GEO?', answer: 'Generative Engine Optimisation; get mentions in Generative Experiences.' },
	{ question: 'What is AI Search?', answer: 'Umbrella term for AEO / GEO.' },
	{ question: 'What is Agentic Commerce?', answer: 'Get your product, service and brand chosen & purchased by agents.' },
	{ question: 'What is MCP?', answer: 'Model Context Protocol; the infrastructure for the Agentic Web.' },
	{ question: 'What is ACP?', answer: "Agentic Commerce Protocol by OpenAI; UCP is Google's variant." },
	{ question: 'What is GEA?', answer: 'Generative Engine Advertising; sponsored placements in generative experiences.' },
	{ question: 'What is Prompt Marketing?', answer: 'Prompt Marketing: the new discipline of marketing in the AI Search era.' }
]
// - CTA data
const ctaData = {
	title: 'Ready to Dominate the New Search Era?',
	text: "Most brands discover they're invisible to AI, or worse, misrepresented. A GEO Readiness Audit reveals exactly where you stand.",
	buttonLink: '/contact',
	buttonText: "Let's Talk"
}
---

<Layout title={SEO.title} description={SEO.description}>
	<OrganizationSchema />
	<WebSiteSchema />
	<FAQPageSchema items={faqSchemaItems} />
	<ServiceSchema name="Prompt Intelligence" description="Measurement & research: competitive visibility analysis, AI Selection Rate tracking, and LLM brand sentiment analysis." />
	<ServiceSchema name="Prompt Optimisation" description="Relevance engineering: SXO & semantic architecture, entity optimisation, and content authority signals for machine trust." />
	<ServiceSchema name="Prompt Commerce" description="Prepare for agentic transactions: AI agent optimisation, data provenance, and agentic protocol setup for ACP, UCP, and MCP." />
	<ServiceSchema name="Prompt Advertising" description="Amplify AI presence: generative engine advertising, AI advertising insights, and campaign management with intent signals." />
	<Hero
		title={heroData.title}
		subtitle={heroData.subtitle}
		buttonLink={heroData.buttonLink}
		buttonText={heroData.buttonText}
		buttonClasses={heroData.buttonClasses}
	/>
	<Brand title={brandData.title} />
	<Features />
	<ScrollSpySteps />
	<TestimonialMasonry title={testimonialData.title} subtitle={testimonialData.subtitle} />
	<Faq subtitle={faqData.subtitle} title={faqData.title} />
	<CTA
		title={ctaData.title}
		text={ctaData.text}
		buttonLink={ctaData.buttonLink}
		buttonText={ctaData.buttonText}
	/>
</Layout>
